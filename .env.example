# Neon — webtoon-app/webtoon-backoffice 와 동일 DB 공유. 스키마 소유권은 backoffice.
# Pooled connection — 앱/Vercel 런타임 (호스트에 -pooler 포함)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# Direct connection — prisma migrate 용 (-pooler 없음)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# Auth.js — openssl rand -base64 32 로 생성
AUTH_SECRET="your-auth-secret"
AUTH_URL="http://localhost:3002"

# 소셜 로그인 — webtoon-app 과 동일 계정/자격증명 사용 (모두 선택, 설정된 것만 버튼 노출)
# Google OAuth
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"
# X(Twitter) OAuth 2.0 — callback: {AUTH_URL}/api/auth/callback/twitter
AUTH_TWITTER_ID="your-x-oauth-client-id"
AUTH_TWITTER_SECRET="your-x-oauth-client-secret"
# Facebook OAuth — callback: {AUTH_URL}/api/auth/callback/facebook
AUTH_FACEBOOK_ID="your-facebook-app-id"
AUTH_FACEBOOK_SECRET="your-facebook-app-secret"

# Vercel Blob — vercel 대시보드 Storage 또는 `vercel env pull`
BLOB_READ_WRITE_TOKEN=""
